# Server
PORT=8081

# Database (Supabase / local Docker Postgres)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=civicpulse
DB_USER=civicpulse
DB_PASSWORD=civicpulse

# JWT — use a long random secret in production
JWT_SECRET=civicpulse-dev-secret-civicpulse-dev-secret

# Admin registration secret — required to use POST /api/auth/admin/register
# Set this to a strong random string in production. Leave empty to disable the endpoint.
ADMIN_SECRET=change-me-in-production

# App
APP_VERSION=0.0.1
NODE_ENV=development
