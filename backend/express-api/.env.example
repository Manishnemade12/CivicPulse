# Server
PORT=8081

# Supabase (required)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================================
# AUTHENTICATION
# ============================================================================

# JWT Secret — align with Supabase JWT secret in production
# For development, use any strong secret string
JWT_SECRET=civicpulse-dev-secret-civicpulse-dev-secret-length-min-32-chars

# Admin registration secret — required to use POST /api/auth/admin/register
# Set this to a strong random string in production. Leave empty to disable the endpoint.
ADMIN_SECRET=change-me-in-production

# ============================================================================
# APPLICATION
# ============================================================================

APP_VERSION=0.0.1
NODE_ENV=development

# ============================================================================
# OPTIONAL: CORS Configuration
# ============================================================================
CORS_ORIGIN=http://localhost:3000
